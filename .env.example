VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=your-app-id

# Optional AI tutor (OpenAI via the `generateTutorFeedback` Cloud Function). Leave
# "false" to use only the built-in static hints/feedback. The OpenAI key is NEVER
# in the browser — it is a Firebase secret used only inside the function. Set this
# to "true" AFTER you deploy the function and set its secret:
#   cd functions && npm install
#   npx firebase-tools@latest functions:secrets:set OPENAI_API_KEY
#   npx firebase-tools@latest deploy --only functions
# Requires the Firebase config above, a SIGNED-IN user (the function rejects
# anonymous callers, e.g. the preview-lesson route), and Blaze billing. When
# false/offline/unavailable/signed-out the app always falls back to static text.
VITE_ENABLE_AI_TUTOR=true

# Firebase App Check (protects backend quota for AI Logic, Firestore, etc.).
# reCAPTCHA Enterprise *site key* from the Firebase console (App Check > Apps).
# Leave blank to run locally without App Check; set it to enable App Check in the
# browser. This is a public site key, not a secret.
VITE_FIREBASE_APPCHECK_SITE_KEY=

# Optional App Check debug token for local development only. When set in a dev
# build, the app registers it as `self.FIREBASE_APPCHECK_DEBUG_TOKEN` so an
# unregistered localhost browser can obtain App Check tokens. Generate one in the
# console (App Check > Apps > Manage debug tokens) or copy the value the SDK logs
# on first run. Leave blank in production.
VITE_APPCHECK_DEBUG_TOKEN=
