rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedInOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Generous DoS guard for the per-lesson keyed maps/lists. We intentionally do
    // NOT pin progress to a hardcoded lesson-id allowlist here: that list went
    // stale as the course grew and 403'd legitimate saves once a learner passed
    // the originally-listed lessons. The client is the source of truth for which
    // lessons exist; rules only bound sizes so a doc can't be inflated without limit.
    function maxLessonKeys() {
      return 1000;
    }

    function hasOnlyProgressFields() {
      return request.resource.data.keys().hasOnly([
        'awardedQuestionIds',
        'completedLessonIds',
        'dailyCompletionDates',
        'dailyStudyMinutes',
        'lessonResumeStates',
        'lessonCompletedAt',
        'lessonTimeSpentMs',
        'questionAttempts',
        'topicStats',
        'recentMistakes',
        'spacedRepetition',
        'requiredPracticePassedDates',
        'totalXp',
        'totalCoinsEarned',
        'updatedAt'
      ]);
    }

    function hasRequiredProgressFields() {
      return request.resource.data.keys().hasAll([
        'completedLessonIds',
        'dailyCompletionDates',
        'totalXp',
        'updatedAt'
      ]);
    }

    function hasValidCompletedLessons() {
      return request.resource.data.completedLessonIds is list
        && request.resource.data.completedLessonIds.size() <= maxLessonKeys();
    }

    function hasValidCompletionDates() {
      return request.resource.data.dailyCompletionDates is list
        && request.resource.data.dailyCompletionDates.size() <= 730;
    }

    function hasValidOptionalMaps() {
      return (!('awardedQuestionIds' in request.resource.data)
          || (request.resource.data.awardedQuestionIds is map
            && request.resource.data.awardedQuestionIds.keys().size() <= maxLessonKeys()))
        && (!('dailyStudyMinutes' in request.resource.data)
          || (request.resource.data.dailyStudyMinutes is map
            && request.resource.data.dailyStudyMinutes.keys().size() <= 730))
        && (!('lessonResumeStates' in request.resource.data)
          || (request.resource.data.lessonResumeStates is map
            && request.resource.data.lessonResumeStates.keys().size() <= maxLessonKeys()))
        && (!('topicStats' in request.resource.data)
          || request.resource.data.topicStats is map)
        && (!('recentMistakes' in request.resource.data)
          || (request.resource.data.recentMistakes is list
            && request.resource.data.recentMistakes.size() <= 25))
        // New spaced-repetition map: a map only (NO key constraint, by design), bounded for DoS.
        && (!('spacedRepetition' in request.resource.data)
          || (request.resource.data.spacedRepetition is map
            && request.resource.data.spacedRepetition.keys().size() <= maxLessonKeys()))
        // New daily-required pass dates: a bounded list (~2 years), like dailyCompletionDates.
        && (!('requiredPracticePassedDates' in request.resource.data)
          || (request.resource.data.requiredPracticePassedDates is list
            && request.resource.data.requiredPracticePassedDates.size() <= 730));
    }

    function hasValidProgressTotals() {
      return request.resource.data.totalXp is int
        && request.resource.data.totalXp >= 0
        && request.resource.data.totalXp <= 1000000
        && request.resource.data.updatedAt == request.time;
    }

    function isValidProgressDocument() {
      return hasOnlyProgressFields()
        && hasRequiredProgressFields()
        && hasValidCompletedLessons()
        && hasValidCompletionDates()
        && hasValidOptionalMaps()
        && hasValidProgressTotals();
    }

    // ---- In-progress practice session validators -------------------------
    // The resumable practice session (Feature: resume across exit/logout). One
    // doc per user, a sibling of the progress doc. Like progress, we do NOT deep
    // validate the question/answer arrays (rules can't iterate lists of maps);
    // we enforce a strict top-level schema, scalar types, a server timestamp, and
    // generous size caps purely as DoS guards. Owner-only access is the real lock.
    function hasOnlyPracticeSessionFields() {
      return request.resource.data.keys().hasOnly([
        'version',
        'sessionId',
        'mode',
        'bankQuestions',
        'questionIndex',
        'currentSelectedChoiceId',
        'currentAnswerResult',
        'correctCount',
        'incorrectCount',
        'sessionResponses',
        'challengePhase',
        'challengeQuestions',
        'challengeIndex',
        'challengeCorrectCount',
        'challengeIncorrectCount',
        'challengeTargetCount',
        'challengeUnavailable',
        'srTopicsServed',
        'recommendedAiCount',
        'updatedAt'
      ]);
    }

    function isValidPracticeSessionDocument() {
      return hasOnlyPracticeSessionFields()
        && request.resource.data.keys().hasAll(['version', 'sessionId', 'mode', 'bankQuestions', 'updatedAt'])
        && request.resource.data.version is int
        && request.resource.data.sessionId is string
        && request.resource.data.sessionId.size() <= 200
        && (request.resource.data.mode == 'gate' || request.resource.data.mode == 'free')
        && request.resource.data.bankQuestions is list
        && request.resource.data.bankQuestions.size() >= 1
        && request.resource.data.bankQuestions.size() <= 200
        && request.resource.data.challengeQuestions is list
        && request.resource.data.challengeQuestions.size() <= 50
        && request.resource.data.sessionResponses is list
        && request.resource.data.sessionResponses.size() <= 200
        && request.resource.data.srTopicsServed is list
        && request.resource.data.srTopicsServed.size() <= 200
        && request.resource.data.questionIndex is int
        && request.resource.data.correctCount is int
        && request.resource.data.incorrectCount is int
        && request.resource.data.challengeIndex is int
        && request.resource.data.challengeCorrectCount is int
        && request.resource.data.challengeIncorrectCount is int
        && request.resource.data.challengeTargetCount is int
        && request.resource.data.recommendedAiCount is int
        && request.resource.data.challengeUnavailable is bool
        && request.resource.data.updatedAt == request.time;
    }

    // Validates a cross-user leaderboard row (see the match block below). Used
    // for BOTH create and update so a valid row can never be mutated into an
    // invalid/oversized one. Enforces a strict 4-field schema, immutable
    // self-owned identity, sane string/number bounds, and a server timestamp.
    function isValidLeaderboardEntry(uid) {
      return request.resource.data.keys().hasOnly(['uid', 'displayName', 'totalXp', 'updatedAt'])
        && request.resource.data.keys().hasAll(['uid', 'displayName', 'totalXp', 'updatedAt'])
        && request.resource.data.uid == uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() >= 1
        && request.resource.data.displayName.size() <= 100
        && request.resource.data.totalXp is int
        && request.resource.data.totalXp >= 0
        && request.resource.data.totalXp <= 1000000
        && request.resource.data.updatedAt == request.time;
    }

    // ---- Classes (study groups) validators ------------------------------
    // A class code is 4–12 uppercase letters/digits (matches the client
    // validators in src/classes/classData.ts). The code is ALSO the doc id.
    function isValidClassCode(code) {
      return code is string && code.matches('^[A-Z0-9]{4,12}$');
    }

    // A brand-new class doc: strict 6-field schema, self-owned, the creator is
    // the SOLE initial member (they can't seed others), a bounded non-empty
    // name, and fresh server timestamps. Enforced on create.
    function isValidNewClass(code) {
      return request.resource.data.keys().hasOnly(['code', 'name', 'ownerUid', 'memberUids', 'createdAt', 'updatedAt'])
        && request.resource.data.keys().hasAll(['code', 'name', 'ownerUid', 'memberUids', 'createdAt', 'updatedAt'])
        && isValidClassCode(code)
        && request.resource.data.code == code
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 60
        && request.resource.data.memberUids == [request.auth.uid]
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    // A membership update may change ONLY memberUids + updatedAt; every identity
    // / metadata field is immutable, the member list stays a bounded list, and
    // updatedAt must be the server time. Combined with the join/leave checks
    // below this prevents schema pollution, metadata tampering, and DoS.
    function isMembershipChangeOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids', 'updatedAt'])
        && request.resource.data.code == resource.data.code
        && request.resource.data.name == resource.data.name
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time
        && request.resource.data.memberUids is list
        && request.resource.data.memberUids.size() <= 200;
    }

    // The caller adds ONLY themselves: they weren't a member, they are now, the
    // list grew by exactly one, and every prior member is retained.
    function isJoiningSelf() {
      return !(request.auth.uid in resource.data.memberUids)
        && (request.auth.uid in request.resource.data.memberUids)
        && request.resource.data.memberUids.size() == resource.data.memberUids.size() + 1
        && request.resource.data.memberUids.hasAll(resource.data.memberUids);
    }

    // The caller removes ONLY themselves: they were a member, they aren't now,
    // the list shrank by exactly one, and no one else was removed.
    function isLeavingSelf() {
      return (request.auth.uid in resource.data.memberUids)
        && !(request.auth.uid in request.resource.data.memberUids)
        && request.resource.data.memberUids.size() == resource.data.memberUids.size() - 1
        && resource.data.memberUids.hasAll(request.resource.data.memberUids);
    }

    // ---- Game scores validators -----------------------------------------
    // A game id is a short lowercase slug (matches the arcade registry ids, e.g.
    // 'flappy-bird', '2048'); bounded so junk parent ids can't be created.
    function isValidGameId(gameId) {
      return gameId is string && gameId.matches('^[a-z0-9-]{1,40}$');
    }

    // A per-user game score row: strict 4-field schema, self-owned + immutable
    // identity, a non-negative bounded INTEGER score, a denormalized display name
    // (non-sensitive, length-capped), and a server timestamp. Used on BOTH create
    // and update so a row can never be mutated into an invalid/oversized state.
    function isValidGameScore(uid) {
      return request.resource.data.keys().hasOnly(['uid', 'displayName', 'score', 'updatedAt'])
        && request.resource.data.keys().hasAll(['uid', 'displayName', 'score', 'updatedAt'])
        && request.resource.data.uid == uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() >= 1
        && request.resource.data.displayName.size() <= 100
        && request.resource.data.score is int
        && request.resource.data.score >= 0
        && request.resource.data.score <= 1000000000
        && request.resource.data.updatedAt == request.time;
    }

    match /users/{userId}/learning/progress {
      allow read: if isSignedInOwner(userId);
      allow create, update: if isSignedInOwner(userId) && isValidProgressDocument();
      allow delete: if isSignedInOwner(userId);
    }

    // The resumable in-progress practice session: owner-only read/write, fully
    // schema- and size-validated on create/update (see isValidPracticeSessionDocument).
    match /users/{userId}/learning/practiceSession {
      allow read: if isSignedInOwner(userId);
      allow create, update: if isSignedInOwner(userId) && isValidPracticeSessionDocument();
      allow delete: if isSignedInOwner(userId);
    }

    match /users/{userId}/{document=**} {
      allow read, write: if false;
    }

    // Slipstream (online, N players). The match doc id IS the room code; the code
    // is an unguessable capability used to find/join a race, so any signed-in
    // user may GET a single match doc BY ITS CODE (but may NOT list/enumerate the
    // collection), while the participant roster, the status lifecycle
    // and the per-player live state are all tightly locked down. A room holds any
    // number of players; a generous size cap (RACE_MAX_PARTICIPANTS) is enforced
    // purely as a resource-exhaustion guard, not a product limit.
    //
    // The match lifecycle has exactly three allowed update transitions, each with
    // an explicit identity/ownership check, and the room's identity + fairness
    // config (host, seed, chapter pool, distance) is frozen across ALL of them:
    //   (A) a signed-in user appends ONLY themselves while the room is `waiting`,
    //   (B) ONLY the host flips a `waiting` room to `racing`,
    //   (C) a participant records the FIRST finish (themselves) -> `finished`.
    match /raceMatches/{matchId} {
      // Generous DoS guard on the unbounded "any number of players" roster.
      function raceMaxParticipants() { return 100; }

      // Identity + fairness config can never change after creation, on any update
      // transition, so no client can re-key the host, the shared seed, the
      // question pool or the finish distance mid-lobby or mid-race.
      function raceConfigUnchanged() {
        return request.resource.data.hostUid == resource.data.hostUid
          && request.resource.data.seed == resource.data.seed
          && request.resource.data.chapterIds == resource.data.chapterIds
          && request.resource.data.raceDistance == resource.data.raceDistance;
      }

      // (A) Join: a signed-in user appends ONLY themselves to a still-`waiting`
      // room. Status stays `waiting`, the winner stays unset, the roster grows by
      // exactly one, the caller was NOT in it and now is, EVERY prior participant
      // is retained (so nobody can be removed) and the host stays first. Together
      // these admit exactly one new uid — the caller — and forbid removals,
      // impersonation and host displacement. Capped to guard against abuse.
      function isJoiningWaitingRace() {
        return resource.data.status == 'waiting'
          && request.resource.data.status == 'waiting'
          && request.resource.data.winnerUid == resource.data.winnerUid
          && request.resource.data.participants is list
          && request.resource.data.participants.size() == resource.data.participants.size() + 1
          && request.resource.data.participants.size() <= raceMaxParticipants()
          && !(request.auth.uid in resource.data.participants)
          && (request.auth.uid in request.resource.data.participants)
          && request.resource.data.participants.hasAll(resource.data.participants)
          && request.resource.data.participants[0] == resource.data.participants[0];
      }

      // (B) Start: ONLY the host flips the room from `waiting` to `racing`. The
      // roster and the (still-unset) winner are frozen across the flip, so
      // starting can neither add players nor pre-pick a winner.
      function isHostStartingRace() {
        return request.auth.uid == resource.data.hostUid
          && resource.data.status == 'waiting'
          && request.resource.data.status == 'racing'
          && request.resource.data.participants == resource.data.participants
          && request.resource.data.winnerUid == resource.data.winnerUid;
      }

      // (C) Finish: a participant records the FIRST finish, only while the race is
      // running and unclaimed, only naming THEMSELVES as the winner, flipping the
      // race to `finished` without touching the roster.
      function isClaimingRaceWin() {
        return request.auth.uid in resource.data.participants
          && resource.data.status == 'racing'
          && resource.data.winnerUid == null
          && request.resource.data.winnerUid == request.auth.uid
          && request.resource.data.status == 'finished'
          && request.resource.data.participants == resource.data.participants;
      }

      // get: any signed-in user may read ONE match doc by its (unguessable) code —
      // the capability needed to find/join a race. list: DENIED so the collection
      // (every room code, host uid and participant uid) can't be enumerated by any
      // signed-in account. The client only ever reads a match by exact id (see
      // subscribeMatch/matchDocRef), so denying list breaks nothing.
      allow get: if request.auth != null;
      allow list: if false;
      allow create: if request.auth != null
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.participants == [request.auth.uid]
        && request.resource.data.status == 'waiting'
        && request.resource.data.winnerUid == null;
      allow update: if request.auth != null
        && raceConfigUnchanged()
        && (isJoiningWaitingRace() || isHostStartingRace() || isClaimingRaceWin());

      match /players/{uid} {
        // Reads + writes are locked to the match's own participants, and a player
        // may write ONLY their own live-state doc (doc id == uid). The roster is
        // append-only and join-before-start, so the participant set a client
        // writes against is the same one everyone races within.
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/raceMatches/$(matchId)).data.participants;
        allow write: if request.auth != null
          && request.auth.uid == uid
          && request.auth.uid in get(/databases/$(database)/documents/raceMatches/$(matchId)).data.participants;
      }
    }

    // Cross-user leaderboard. One row per user, the doc id IS the user's uid.
    // The row holds ONLY non-sensitive, denormalized display data (no email or
    // other PII), so any signed-in user may read the board to rank everyone.
    // Writes are restricted to the owner of the row AND fully validated on both
    // create and update (see isValidLeaderboardEntry), preventing identity
    // spoofing, schema pollution, oversized-payload DoS, and out-of-range XP.
    match /leaderboard/{uid} {
      allow read: if request.auth != null;
      allow create, update: if isSignedInOwner(uid) && isValidLeaderboardEntry(uid);
      allow delete: if isSignedInOwner(uid);
    }

    // Classes (study groups). The doc id IS the class code. A class doc holds
    // only non-sensitive, denormalized data (code, name, owner uid, member uids
    // — NO email or other PII), so:
    //   • get  — any signed-in user may read a single class by its code (needed
    //            to join by code and to read the member list for the per-class
    //            leaderboard). The code is an unguessable capability to join.
    //   • list — restricted to classes the caller is a member of, so the full
    //            catalog of class codes can't be enumerated via a query.
    //   • create — fully validated: the creator owns it and is the SOLE initial
    //            member, with a strict schema and bounded fields.
    //   • update — only a self join/leave of memberUids is allowed; all identity
    //            and metadata fields are immutable, so a user can add/remove
    //            ONLY themselves and can never tamper with the class or others.
    //   • delete — owner only.
    // Per-user lifetime XP for the per-class board comes from leaderboard/{uid}
    // (above), so XP is never stored on — or mutable through — class docs.
    match /classes/{code} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (request.auth.uid in resource.data.memberUids);
      allow create: if isSignedIn() && isValidNewClass(code);
      allow update: if isSignedIn()
        && isMembershipChangeOnly()
        && (isJoiningSelf() || isLeavingSelf());
      allow delete: if isSignedIn() && request.auth.uid == resource.data.ownerUid;
    }

    // Per-game GLOBAL high-score leaderboards. One row per user per game; the
    // score doc id IS the user's uid. Rows hold only non-sensitive denormalized
    // data (uid, displayName, score — NO PII), so any signed-in user may READ the
    // board to rank everyone. A user may WRITE only their OWN row (doc id / uid
    // == request.auth.uid), the row is fully validated on create AND update, and
    // an update's score must be monotonically non-decreasing (best-only), so a
    // player can't tamper with others' scores or corrupt their own row's schema.
    match /gameScores/{gameId}/scores/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedInOwner(uid)
        && isValidGameId(gameId)
        && isValidGameScore(uid);
      allow update: if isSignedInOwner(uid)
        && isValidGameId(gameId)
        && isValidGameScore(uid)
        && request.resource.data.score >= resource.data.score;
      allow delete: if isSignedInOwner(uid);
    }
  }
}
